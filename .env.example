TIANHAI_APP_ID=tianhai
TIANHAI_APP_NAME=TianHai
TIANHAI_ENVIRONMENT=local

# Leave empty for local SQLite. Set to postgresql+psycopg://... for durable production state.
TIANHAI_DATABASE_URL=
TIANHAI_SQLITE_DB_FILE=data/tianhai-agentos.db

# Keep disabled by default during local foundation work.
TIANHAI_AGENTOS_TELEMETRY=false
TIANHAI_AGENTOS_RELOAD=false
TIANHAI_AGENTOS_AUTO_PROVISION_DBS=true
